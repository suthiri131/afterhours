<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - After Hours</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        margin: 0;
        padding: 0;
      }

      .container {
        width: 400px;
        margin: 80px auto;
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      }

      h1 {
        text-align: center;
        margin-bottom: 25px;
      }

      .error {
        color: red;
        background-color: #ffe5e5;
        border: 1px solid #ffb3b3;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 15px;
      }

      label {
        display: block;
        margin-bottom: 6px;
        font-weight: bold;
      }

      input {
        width: 100%;
        padding: 10px;
        margin-bottom: 18px;
        border: 1px solid #ccc;
        border-radius: 5px;
        box-sizing: border-box;
      }

      button {
        width: 100%;
        padding: 12px;
        background-color: #222;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 16px;
      }

      button:hover {
        background-color: #444;
      }

      .links {
        text-align: center;
        margin-top: 20px;
      }

      .links a {
        color: #0066cc;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Forgot Password</h1>

      <% if (msg) { %>
        <div class="error"><%= msg %></div>
      <% } %>

      <form action="/user/forgot-password" method="POST">
        <label for="email">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          value="<%= typeof email !== 'undefined' ? email : '' %>"
        />

        <label for="username">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          required
          value="<%= typeof username !== 'undefined' ? username : '' %>"
        />

        <button type="submit">Verify Account</button>
      </form>

      <div class="links">
        <p><a href="/user/login">Back to Login</a></p>
      </div>
    </div>
  </body>
</html>