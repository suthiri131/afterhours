<!DOCTYPE html>
<html lang="en">

  <head>

    <meta charset="UTF-8" />
    <title>Admin Edit Movie Page</title>
    <style>

      body {
        font-family: Arial, sans-serif;
        color: #0f172a;
      }

      .container {
        max-width: 500px;
        margin: 40px auto;
        padding: 0 20px;
      }

      .msg {
        color: #b91c1c;
        margin-bottom: 12px;
      }

      .btn {
        background-color: #14213d;
        color: #ffffff;
        border: none;
        cursor: pointer;
        padding: 8px 16px;
        text-decoration: none;
        display: inline-block;
      }

      .btn:hover {
        background-color: #1d4ed8;
      }

    </style>

  </head>

  <body>

    <div class="container">

      <h1>Admin Edit Movie Page</h1>

      <% if (errors && errors.length > 0) { %>
        <div class="msg">
          <ol>
            <% errors.forEach(error => { %>
              <li><%= error %></li>
            <% }) %>
          </ol>
        </div>
      <% } %>

      <form action="/admin/movies/<%= movie._id %>/edit" method="POST" enctype="multipart/form-data">

        Title<br>
        <input type="text" name="title" value="<%= formData ? formData.title : movie.title %>"><br><br>

        Genre<br>
        <select name="genre">
          <option value="">-- Select Genre --</option>
          <option value="Action" <%= (formData ? formData.genre : movie.genre) === "Action" ? "selected" : "" %>>Action</option>
          <option value="Adventure" <%= (formData ? formData.genre : movie.genre) === "Adventure" ? "selected" : "" %>>Adventure</option>
          <option value="Animation" <%= (formData ? formData.genre : movie.genre) === "Animation" ? "selected" : "" %>>Animation</option>
          <option value="Comedy" <%= (formData ? formData.genre : movie.genre) === "Comedy" ? "selected" : "" %>>Comedy</option>
          <option value="Crime" <%= (formData ? formData.genre : movie.genre) === "Crime" ? "selected" : "" %>>Crime</option>
          <option value="Documentary" <%= (formData ? formData.genre : movie.genre) === "Documentary" ? "selected" : "" %>>Documentary</option>
          <option value="Drama" <%= (formData ? formData.genre : movie.genre) === "Drama" ? "selected" : "" %>>Drama</option>
          <option value="Fantasy" <%= (formData ? formData.genre : movie.genre) === "Fantasy" ? "selected" : "" %>>Fantasy</option>
          <option value="Horror" <%= (formData ? formData.genre : movie.genre) === "Horror" ? "selected" : "" %>>Horror</option>
          <option value="Musical" <%= (formData ? formData.genre : movie.genre) === "Musical" ? "selected" : "" %>>Musical</option>
          <option value="Mystery" <%= (formData ? formData.genre : movie.genre) === "Mystery" ? "selected" : "" %>>Mystery</option>
          <option value="Romance" <%= (formData ? formData.genre : movie.genre) === "Romance" ? "selected" : "" %>>Romance</option>
          <option value="Sci-Fi" <%= (formData ? formData.genre : movie.genre) === "Sci-Fi" ? "selected" : "" %>>Sci-Fi</option>
          <option value="Thriller" <%= (formData ? formData.genre : movie.genre) === "Thriller" ? "selected" : "" %>>Thriller</option>
        </select><br><br>

        Director<br>
        <input type="text" name="director" value="<%= formData ? formData.director : movie.director || '' %>"><br><br>

        Release Year<br>
        <input type="number" name="releaseYear" value="<%= formData ? formData.releaseYear : movie.releaseYear || '' %>"><br><br>

        Description<br>
        <textarea name="description" rows="6" cols="60"><%= formData ? formData.description : movie.description || '' %></textarea><br><br>

        Movie Image<br>
        <input type="file" name="movieImage" accept="image/*"
        style="border: 1px solid #ccc; padding: 4px;"><br>
        <small>Accepted formats: JPEG, JPG, PNG, WEBP (max 5MB)</small><br>
        <small>Leave empty to keep existing image. If there is an error, please re-attach the image.</small><br><br>

        <button type="submit" class="btn">Save Changes</button>

      </form>

      <br>
      <a href="/admin/movies" class="btn">Back to movie list</a>

    </div>

  </body>

</html>