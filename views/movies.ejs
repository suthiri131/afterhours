<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Movies</title>

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background-color: #f5f7fb;
        color: #1f2937;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 28px 20px;
      }

      .title {
        margin: 0 0 6px;
        font-size: 28px;
        color: #14213d;
      }

      .subtitle {
        margin: 0 0 24px;
        font-size: 14px;
        color: #6b7280;
      }

      .instruction {
        margin-bottom: 20px;
      }

      .message {
        margin-bottom: 18px;
        padding: 12px 14px;
        border-radius: 10px;
        background-color: #fee2e2;
        color: #991b1b;
        font-size: 13px;
      }

      .message.success {
        background-color: #d1fae5;
        color: #065f46;
      }

      .filter-wrap {
        margin-bottom: 24px;
      }

      .filter-label {
        display: block;
        margin-bottom: 8px;
        font-size: 14px;
        font-weight: 600;
        color: #14213d;
      }

      .filter-select {
        min-width: 220px;
        padding: 10px 12px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background-color: #fff;
        font-size: 14px;
        color: #1f2937;
        outline: none;
      }

      .filter-select:focus {
        border-color: #14213d;
      }

      .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 18px;
      }

      .movie-card {
        background-color: white;
        border-radius: 20px;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 260px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .movie-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.1);
      }

      .movie-banner {
        height: 410px;
        min-height: 410px; 
        max-width: 300px;
        width: 100%;
        width: 100%;
        background-color: #14213d;
        overflow: hidden;
        display: block;
      }

      .movie-banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .movie-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 42px;
        font-weight: bold;
      }

     .movie-content {
  padding: 12px;
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 3px;
}

.movie-title {
  font-size: 15px;
  line-height: 1.4;
  margin: 0 0 2px;
  color: #14213d;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 28px;
}

      .movie-title a {
        text-decoration: none;
        color: inherit;
      }

      .movie-title a:hover {
        text-decoration: underline;
      }

      .movie-info {
        display: inline-flex;
        gap: 10px;
        flex-wrap: wrap;
        margin: 0;
      }

      .badge {
        display: inline-flex;
        white-space: nowrap;  /* Prevents the text from wrapping to a new line */
        padding: 5px 8px;
        border-radius: 6px;
        background-color: #eef2ff;
        font-size: 11px;
        color: #14213d;
      }

      .description {
        font-size: 13px;
        color: #4b5563;
        margin: 0;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .director {
        font-size: 12px;
        color: #374151;
        margin: 0;
      }

      .watchlist-form {
        margin-top: auto;
        padding-top: 6px;
      }

      .btn {
        width: 100%;
        border: none;
        border-radius: 10px;
        padding: 10px;
        background-color: #14213d;
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
      }

      .btn:hover {
        background-color: #1f325c;
      }

      .empty {
        text-align: center;
        padding: 40px;
        background: white;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        color: #6b7280;
      }

      @media (max-width: 768px) {
        .container {
          padding: 24px 16px;
        }

        .title {
          font-size: 24px;
        }

        .movies-grid {
          grid-template-columns: 1fr;
        }

        .movie-card {
          max-width: 100%;
        }

        .movie-banner {
          height: 260px;
          min-height: 260px;
        }
      }

      h3 {
        margin-bottom: 8px;
      }

      .genre-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 10px 0 20px;
      }

      .tag {
        cursor: pointer;
      }

      .tag input {
        display: none;
      }

      .tag span {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 8px;
        background-color: #e3e7f3;
        font-size: 13px;
        transition: all 0.2s ease;
      }

      /* Hover */
      .tag span:hover {
        background-color: #c7d2fe;
      }

      /* Selected */
      .tag input:checked + span {
        background-color: #14213d;
        color: white;
      }

      .search-bar {
        background-color: #e3e7f3;
        border: none;
        border-radius: 10px;
        padding: 10px 15px;
        width: 100%;
      }

      .search-bar::placeholder {
        color: #14213d;
      }

      .trending-container {
        border: 2px solid #14213d;
        border-radius: 16px;
        padding: 20px;
        background-color: #f0f4ff;
        margin-bottom: 30px;
      }

      .trending-card {
        position: relative;
        border: 2px solid #f59e0b;
      }

      .rank-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background-color: #f59e0b;
        color: white;
        font-weight: bold;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 14px;
        z-index: 10;
      }
    </style>
  </head>

  <body>
    <%- include("navbar") %>

    <div class="container">
      <h1 class="title">All Movies</h1>

      <% if (user) { %>
        <p class="subtitle">Welcome, <%= user.username %></p>
      <% } %>

      <p class="subtitle instruction">
        Click the poster or title to view details and reviews.
      </p>

      <% if (typeof msg !== "undefined" && msg) { %>
        <div class="message <%= msg.includes('Successfully') ? 'success' : '' %>">
          <%= msg %>
        </div>
      <% } %>

      <form id="filterForm" method="GET" action="/movies">
      <h3>Movie Title Filter:</h3>
        <!-- Search -->
        <input class="search-bar" 
          type="text" 
          name="search" 
          placeholder="Search movie title..."
          value="<%= search || '' %>"
        />
      <h3>Genre Filter:</h3>
        <!-- Genre Tags -->
        <div class="genre-tags">
          <% genres.forEach(g => { %>
            <label class="tag">
              <input 
                type="checkbox" 
                name="genre" 
                value="<%= g._id %>"
                <%= Array.isArray(selectedGenre) && selectedGenre.includes(g._id.toString()) ? "checked" : "" %>
                onchange="this.form.submit()">
              <span><%= g.name %></span>
            </label>
          <% }) %>
        </div>

      </form>

      <br>

      <h2>🔥 Trending Movies 🔥</h2>
      <div class="trending-container">
        <div class="movies-grid">
          <% trendingMovies.forEach((movie,index) => { %>
            <div class="movie-card trending-card">
              <div class="movie-banner">
                <a href="/movies/<%= movie._id %>">
                  <% if (movie.movieImage) { %>
                    <img src="<%= movie.movieImage %>">
                  <% } else { %>
                    <div class="movie-placeholder">
                      <%= movie.title.charAt(0).toUpperCase() %>
                    </div>
                  <% } %>
                </a>
              </div>
              <div class="rank-badge">#<%= index + 1 %></div>
              
              <div class="movie-content">
                <h2 class="movie-title">
                  <a href="/movies/<%= movie._id %>"><%= movie.title %></a>
                </h2>
                <p class="description">
                  ⭐ <%= movie.avgRating || 0 %> | 👁 <%= movie.views || 0 %> views
                </p>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <br><br><br>
      <% if (!movies || movies.length === 0) { %>
        <div class="empty">
          <p>No movies available</p>
        </div>
      <% } else { %>
        <div class="movies-grid">
          <% movies.forEach(movie => { %>
            <div class="movie-card">
              <div class="movie-banner">
                <a href="/movies/<%= movie._id %>" style="display:block; width:100%; height:100%;">
                  <% if (movie.movieImage) { %>
                    <img src="<%= movie.movieImage %>" alt="<%= movie.title %>">
                  <% } else { %>
                    <div class="movie-placeholder">
                      <%= movie.title ? movie.title.charAt(0).toUpperCase() : "M" %>
                    </div>
                  <% } %>
                </a>
              </div>

              <div class="movie-content">
                <h2 class="movie-title">
                  <a href="/movies/<%= movie._id %>"><%= movie.title %></a>
                </h2>

              <div class="movie-info">
                <% if (movie.genre && movie.genre.length > 0) { %>
                  <% if (movie.genre.length === 1) { %> 
                    <!-- for movie w 1 genre -->
                    <span class="badge"><%= movie.genre[0].name %></span>
                  <% } else { %>
                    <!-- for movie w more than 1 genre -->
                    <span class="badge"><%= movie.genre[0].name %>...</span>
                    <% } %>
                  <% } else { %>
                  <span class="badge">Unknown Genre</span>
                <% } %>

                <% if (movie.releaseYear) { %>
                  <span class="badge"><%= movie.releaseYear %></span>
                <% } %>
              </div>

                <p class="description">
                  <%= movie.description && movie.description.trim() !== ""
                    ? movie.description
                    : "No description available" %>
                </p>

                <p class="director">
                  <strong>Director:</strong>
                  <%= movie.director && movie.director.trim() !== "" ? movie.director : "Unknown" %>
                </p>

                <form class="watchlist-form" action="/watchlist/add/<%= movie._id %>" method="POST">
                  <button type="submit" class="btn">Add to Watchlist</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </body>
</html>