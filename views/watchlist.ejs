<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Watchlist</title>

    <style>
      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background-color: #f5f7fb;
        color: #1f2937;
      }

      .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        background-color: #14213d;
        color: white;
      }

      .logo { font-size: 20px; font-weight: bold; }

      .right { display: flex; gap: 16px; }

      .link {
        color: white;
        text-decoration: none;
        font-size: 14px;
      }

      .link:hover { text-decoration: underline; }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 28px 20px;
      }

      .title {
        margin: 0 0 6px;
        font-size: 28px;
        color: #14213d;
      }

      .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 18px;
      }

      .movie-card {
        background-color: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .movie-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.1);
      }

      .movie-banner {
        height: 410px; 
        min-height: 410px; 
        
        width: 100%;
        background-color: #14213d;
        overflow: hidden;
        display: block; 
      }

      .movie-banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .movie-content {
        padding: 14px;
        display: flex;
        flex-direction: column;
        flex: 1;
      }

      .movie-title {
        font-size: 16px;
        line-height: 1.4;
        margin: 0 0 8px;
        color: #14213d;
      }

      .movie-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: auto;
      }

      .badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 999px;
        background-color: #eef2ff;
        font-size: 11px;
        color: #14213d;
        margin-bottom: 12px;
      }

      .btn {
        width: 100%;
        border: none;
        border-radius: 8px;
        padding: 10px;
        background-color: #14213d;
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        margin-top: auto;
      }

      .btn-disabled{
        background-color: #dde0e3;
        color: #9399a4;
      }

      .btn-delete {
        width: 100%;
        border: none;
        border-radius: 8px;
        padding: 10px;
        background-color: #991b1b;
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        margin-top: auto;
      }

      .btn-delete:hover {
        background-color: #7f1d1d;
      }

      .empty-state {
        text-align: center;
        padding: 50px;
        background: white;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
      }

      .link-back {
        display: inline-block;
        padding: 10px 20px;
        background-color: #14213d;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
    }
    </style>
</head>
<body>
<%- include("navbar") %>
    <div class="container">
        <h1>My Watchlist (<%= movies.length %>)</h1>

        <% if (typeof movies !== 'undefined' && movies !== null && movies.length > 0) { %>
            <div class="movies-grid">
                <% movies.forEach(item => { %>
                    <% if (item.movieId) { %>
                        <div class="movie-card">
                            <div class="movie-banner">
                              <a href="/movies/<%= item.movieId._id %>" style="display:block; width:100%; height:100%;">
                                  <% if (item.movieId.movieImage) { %>
                                      <img src="<%= item.movieId.movieImage %>" alt="<%= item.movieId.title %>">
                                  <% } else { %>
                                      <div class="placeholder">No Image</div>
                                  <% } %>
                              </a>
                            </div>

                            <div class="movie-content">
                                <h2 class="movie-title">
                                    <a href="/movies/<%= item.movieId._id %>" style="text-decoration:none; color:inherit;">
                                        <%= item.movieId.title %>
                                    </a>
                                </h2>
                                <div class="movie-info">
                                    <span class="badge <%= item.status === 'Watched' ? 'status-watched' : 'status-plan' %>">
                                        <%= item.status ? item.status : 'Plan to Watch' %>
                                    </span>
                                </div>

                                <!-- updated by thet -->
                                <!-- show users where to view full ratings and reviews -->
                                <% if (item.status === "Watched") { %>
                                  <p style="margin: 0 0 12px 0; font-size: 12px; color: #6b7280; text-align: center;">
                                      Click the movie poster or title to see full ratings and reviews.
                                  </p>
                                <% } %>

                                <!-- updated by thet -->
                                <!-- if movie is not watched yet, show Mark as Watched button -->
                                <!-- if already watched with no review, show Write a Review -->
                                <!-- if already watched with review, show Edit Review -->
                                <!-- Remove button is always available -->
                                <div class="movie-actions">
                                  <% if (item.status !== "Watched") { %>
                                      <form action="/watchlist/watched/<%= item._id %>" method="POST">
                                          <input type="hidden" name="returnTo" value="/watchlist">
                                          <button type="submit" class="btn btn-watch">
                                              Mark as Watched
                                          </button>
                                      </form>
                                  <% } %>

                                  <% if (item.status === "Watched" && !item.hasReview) { %>
                                      <a href="/reviews/movie/<%= item.movieId._id %>/new" class="btn" style="text-align:center; text-decoration:none;">
                                          Write a Review
                                      </a>
                                  <% } %>

                                  <% if (item.status === "Watched" && item.hasReview) { %>
                                      <a href="/reviews/<%= item.reviewId %>/edit" class="btn" style="text-align:center; text-decoration:none;">
                                          Edit Review
                                      </a>
                                  <% } %>

                                  <form action="/watchlist/delete/<%= item._id %>" method="POST" class="form-delete">
                                      <button type="submit" class="btn-delete">Remove</button>
                                  </form>
                                </div>
                            </div>
                        </div>
                    <% } %>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>Your watchlist is empty. Go add some movies!</p>
                <a href="/movies" class="link-back">Back to All Movies</a>
            </div>
        <% } %>
    </div>
</body>
</html>