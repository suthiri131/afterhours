<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>My Profile</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #f5f7fb;
      color: #0f172a;
    }

    .container {
      width: 100%;
      max-width: 420px;
      margin: 40px auto 20px;
      background-color: #ffffff;
      padding: 36px 32px;
      border-radius: 14px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      box-sizing: border-box;
    }

    h1 {
      margin: 0 0 24px 0;
      font-size: 24px;
      font-weight: 700;
      color: #14213d;
      text-align: center;
    }

    .message {
      margin-bottom: 15px;
      font-size: 14px;
      text-align: center;
    }

    .message.success {
      color: green;
    }

    .message.error {
      color: red;
    }

    .profile p {
      margin: 12px 0;
      font-size: 15px;
      line-height: 1.5;
    }

    .label {
      font-weight: bold;
      color: #14213d;
    }

    .btn {
      display: block;
      width: 100%;
      box-sizing: border-box;
      margin-top: 16px;
      padding: 11px;
      background-color: #14213d;
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      text-align: center;
      border: none;
      cursor: pointer;
    }

    .btn:hover {
      background-color: #1d4ed8;
    }

    .delete-btn {
      background-color: #b91c1c;
    }

    .delete-btn:hover {
      background-color: #991b1b;
    }

    .logout-wrapper {
      max-width: 420px;
      margin: 0 auto 30px;
    }

    .logout-btn {
      width: 100%;
      padding: 11px;
      background-color: #64748b;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
    }

    .logout-btn:hover {
      background-color: #475569;
    }

    .empty {
      text-align: center;
      font-size: 14px;
    }
  </style>
</head>

<body>

  <%- include("../navbar") %>

  <div class="container">
    <h1>My Profile</h1>

    <% if (msg) { %>
      <div class="message <%= type === 'success' ? 'success' : 'error' %>"><%= msg %></div>
    <% } %>

    <% if (user) { %>
      <div class="profile">
        <p><span class="label">Full Name:</span> <%= user.fullName %></p>
        <p><span class="label">Username:</span> <%= user.username %></p>
        <p><span class="label">Email:</span> <%= user.email %></p>
        <p><span class="label">Joined:</span> <%= user.createdAt.toDateString() %></p>
      </div>

      <a href="/user/change-password" class="btn">Change Password</a>
      <a href="/user/delete" class="btn delete-btn">Delete My Account</a>

    <% } else { %>
      <p class="empty">User profile not available.</p>
    <% } %>
  </div>

  <% if (user) { %>
    <div class="logout-wrapper">
      <form action="/user/logout" method="POST">
        <button type="submit" class="logout-btn">Logout</button>
      </form>
    </div>
  <% } %>

</body>
</html>