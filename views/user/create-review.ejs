<%# thet %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Write Review</title>
  <link rel="stylesheet" href="/css/review-form.css" />
  <link rel="stylesheet" href="/css/review-movie-poster.css" />
</head>
<body>
  <%- include("../navbar") %>
  <div class="page-container">
    <a href="/movies/<%= movie._id %>" class="back-link">← Back to Movie Details</a>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <div class="review-layout">
      <section class="panel">
        <h2 class="section-label">Step 1: Review Tips</h2>
        <%- include("review-movie-poster", {
          movie: movie,
          showAverageBox: false
        }) %>

        <hr>
        <ul class="guideline-list">
          <li>Write a short interesting headline.</li>
          <li>Rate each category honestly.</li>
          <li>Keep your review helpful and easy to read.</li>
          <li>Avoid major spoilers if possible.</li>
          <li>The overall score is calculated automatically.</li>
        </ul>
      </section>

      <section class="panel">
        <h2 class="section-label">Step 2: Rate This Movie</h2>

        <form action="/reviews/movie/<%= movie._id %>" method="POST">
          <%- include("review-rating-fields", { formData: formData }) %>

          <%- include("review-form-fields", {
            formData: formData,
            movie: movie,
            formTitle: "Step 3: Write Your Review",
            subtext: "Add a headline and write your thoughts below.",
            reviewPlaceholder: "Share your thoughts here...",
            submitLabel: "Submit Review"
          }) %>
        </form>
      </section>
    </div>
  </div>

  <script>
    const categoryNames = ["storyRating", "actingRating", "musicRating", "rewatchRating"];
    const overallValue = document.getElementById("overallValue");

    function updateOverall() {
      let total = 0;
      let count = 0;

      categoryNames.forEach((name) => {
        const checked = document.querySelector(`input[name="${name}"]:checked`);
        if (checked) {
          total += Number(checked.value);
          count++;
        }
      });

      if (count === 4) {
        const avg = (total / 4).toFixed(1);
        overallValue.textContent = `${avg} / 5.0`;
      } else {
        overallValue.textContent = "0.0 / 5.0";
      }
    }

    document.querySelectorAll('input[type="radio"]').forEach((input) => {
      input.addEventListener("change", updateOverall);
    });

    updateOverall();
  </script>
</body>
</html>