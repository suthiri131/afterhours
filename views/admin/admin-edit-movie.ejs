<!DOCTYPE html>
<html lang="en">

  <head>

    <meta charset="UTF-8" />
    <title>Admin Edit Movie Page</title>
    <style>

      body {
        font-family: Arial, sans-serif;
        color: #0f172a;
      }

      .container {
        max-width: 500px;
        margin: 40px auto;
        padding: 0 20px;
      }

      .msg {
        color: #b91c1c;
        margin-bottom: 12px;
      }

      .btn {
        background-color: #14213d;
        color: #ffffff;
        border: none;
        cursor: pointer;
        padding: 8px 16px;
        text-decoration: none;
        display: inline-block;
      }

      .btn:hover {
        background-color: #1d4ed8;
      }

    </style>

  </head>

  <body>

    <%- include("../navbar") %>

    <div class="container">

      <h1>Admin Edit Movie Page</h1>
      <p><em>* Please ensure that all fields in the form are filled in before submitting</em></p>

      <% if (errors && errors.length > 0) { %>
        <div class="msg">
          <ol>
            <% errors.forEach(error => { %>
              <li><%= error %></li>
            <% }) %>
          </ol>
        </div>
      <% } %>

      <form action="/admin/movies/<%= movie._id %>/edit" method="POST" enctype="multipart/form-data">

        Title<br>
        <input type="text" name="title" value="<%= formData ? formData.title : movie.title %>"><br><br>

        Genre<br>
        <small><em>Hold Ctrl (Windows) or Cmd (Mac) to select multiple genres.</em></small><br>
        <select name="genre" multiple size="6">
          <% genres.forEach(g => { %>
            <%
              const selectedGenres = formData
                ? (formData.genre || []).map(String)
                : (movie.genre || []).map(g => String(g._id));
              const isSelected = selectedGenres.includes(String(g._id));
            %>
            <option value="<%= g._id %>" <%= isSelected ? "selected" : "" %>>
              <%= g.name %>
            </option>
          <% }) %>
        </select><br><br>

        Director<br>
        <input type="text" name="director" value="<%= formData ? formData.director : movie.director || '' %>"><br><br>

        Release Year<br>
        <input type="number" name="releaseYear" value="<%= formData ? formData.releaseYear : movie.releaseYear || '' %>"><br><br>

        Description<br>
        <textarea name="description" rows="6" cols="60"><%= formData ? formData.description : movie.description || '' %></textarea><br><br>

        Movie Image<br>
        <input type="file" name="movieImage" accept="image/*"
        style="border: 1px solid #ccc; padding: 4px;"><br>
        <small>Accepted formats: JPEG, JPG, PNG, WEBP (max 5MB)</small><br>
        <small>Leave empty to keep existing image. If there is an error, please re-attach the image.</small><br><br>

        <button type="submit" class="btn">Save Changes</button>

      </form>

      <br>
      <a href="/admin/movies" class="btn">Back to movie list</a>

    </div>

  </body>

</html>