<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit Genre</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #f5f7fb;
      color: #1f2937;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 24px;
      background-color: #14213d;
      color: white;
    }

    .logo {
      font-size: 20px;
      font-weight: bold;
    }

    .right {
      display: flex;
      gap: 16px;
    }

    .link {
      color: white;
      text-decoration: none;
      font-size: 14px;
    }

    .link:hover {
      text-decoration: underline;
    }

    .container {
      max-width: 500px;
      margin: 40px auto;
      background: white;
      padding: 24px;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
    }

    h1 {
      margin-top: 0;
      color: #14213d;
    }

    .msg {
      margin-bottom: 12px;
      padding: 10px;
      border-radius: 6px;
      background-color: #fee2e2;
      color: #991b1b;
      font-size: 13px;
    }

    input {
      width: 100%;
      padding: 10px;
      margin-top: 6px;
      margin-bottom: 16px;
      border-radius: 6px;
      border: 1px solid #ccc;
    }

    .btn {
      background-color: #14213d;
      color: white;
      border: none;
      padding: 10px 14px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
    }

    .btn:hover {
      background-color: #1d4ed8;
    }

    .back {
      display: inline-block;
      margin-top: 12px;
      text-decoration: none;
      font-size: 13px;
      color: #14213d;
    }

    .back:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>

  <%- include("../navbar") %>

  <!-- NAVBAR -->
  <div class="header">
    <div class="logo">AfterHours</div>

    <div class="right">
      <% if (user && user.role === "admin" || "superAdmin") { %>
        <a class="link" href="/admin/movies">Manage Movies</a>
        <a class="link" href="/admin/genres">Genres</a>
      <% } %>
      <a class="link" href="/watchlist">WatchList</a>
      <a class="link" href="/user/profile">Profile</a>
    </div>
  </div>

  <!-- FORM -->
  <div class="container">

    <h1>Edit Genre</h1>

    <% if (msg) { %>
      <div class="msg"><%= msg %></div>
    <% } %>

    <form action="/admin/genres/<%= genre._id %>/edit" method="POST">
      
      Genre Name<br>
      <input 
        type="text" 
        name="name" 
        value="<%= genre.name %>" 
        required
      >

      <button type="submit" class="btn">Save Changes</button>

    </form>

    <a href="/admin/genres" class="back">← Back to Genres</a>

  </div>

</body>
</html>