<%# thet %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= movie.title %> - Movie Details</title>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #f7f8fc, #eef1f8);
      color: #1f2937;
    }

    .page-container {
      width: 92%;
      max-width: 1120px;
      margin: 35px auto;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 20px;
      text-decoration: none;
      color: #374151;
      font-weight: bold;
    }

    .card {
      background: #ffffff;
      border-radius: 18px;
      padding: 24px;
      margin-bottom: 22px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.07);
    }

    .movie-header {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .movie-title {
      margin: 0 0 10px 0;
      font-size: 2rem;
    }

    .movie-meta {
      margin: 8px 0;
      color: #4b5563;
      font-size: 1rem;
    }

    .stats-box {
      min-width: 250px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 18px;
    }

    .stats-number {
      font-size: 2rem;
      font-weight: 700;
      color: #111827;
      margin: 0;
    }

    .stats-sub {
      margin: 6px 0 0 0;
      color: #6b7280;
    }

    .stars-display {
      color: #f5b301;
      letter-spacing: 2px;
      font-size: 1.2rem;
      margin-top: 8px;
    }

    .btn-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .btn {
      display: inline-block;
      padding: 11px 18px;
      text-decoration: none;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: bold;
      font-size: 0.95rem;
      transition: 0.2s ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      opacity: 0.95;
    }

    .btn-primary {
      background: #111827;
      color: white;
    }

    .btn-danger {
      background: #d93025;
      color: white;
    }

    .section-title {
      margin: 0 0 16px 0;
      font-size: 1.35rem;
    }

    .review-list {
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .review-item {
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 18px;
      background: #fcfcfd;
    }

    .own-review-card {
      border: 2px solid #dbeafe;
      background: #f8fbff;
    }

    .review-grid {
      display: grid;
      grid-template-columns: 1fr 210px;
      gap: 18px;
      align-items: start;
    }

    .review-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .reviewer-name {
      font-weight: 700;
      font-size: 1rem;
    }

    .you-badge {
      margin-left: 8px;
      font-size: 0.9rem;
      color: #2563eb;
      font-weight: 600;
    }

    .rating-pill {
      background: #eaf1f8;
      color: #27415d;
      border: 1px solid #d4e1ed;
      border-radius: 999px;
      padding: 7px 12px;
      font-weight: bold;
      font-size: 0.95rem;
    }

    .mini-stars {
      color: #f5b301;
      letter-spacing: 1px;
      margin-left: 6px;
    }

    .review-headline {
      margin: 10px 0 8px 0;
      font-size: 1.5rem;
      font-weight: 700;
      color: #1f2937;
    }

    .review-text {
      margin: 10px 0 0 0;
      line-height: 1.7;
      white-space: pre-wrap;
      color: #1f2937;
    }

    .review-date {
      display: block;
      margin-top: 12px;
      color: #6b7280;
      font-size: 0.9rem;
    }

    .review-edited {
      margin-top: 6px;
      color: #6b7280;
      font-size: 0.9rem;
    }

    .review-owner-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .score-card {
      background: #f8fafc;
      border: 1px solid #dbe3ea;
      border-radius: 14px;
      overflow: hidden;
      min-width: 170px;
    }

    .score-card-head {
      background: #eaf1f8;
      padding: 12px 14px;
      border-bottom: 1px solid #dbe3ea;
      font-weight: 700;
      color: #27415d;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .score-card-score {
      font-weight: 800;
      color: #1d4b7a;
    }

    .score-card-body {
      padding: 12px 14px;
    }

    .score-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      padding: 7px 0;
      border-bottom: 1px solid #edf2f7;
      font-size: 0.95rem;
    }

    .score-row:last-child {
      border-bottom: none;
    }

    .score-label {
      color: #374151;
      font-weight: 600;
    }

    .score-value {
      color: #111827;
      font-weight: 700;
    }

    .empty-state {
      color: #6b7280;
      margin: 0;
    }

    .notice {
      padding: 16px 18px;
      border-radius: 12px;
      background: #fff7ed;         
      color: #9a3412;             
      border: 1px solid #fdba74;
      font-weight: 600;
      font-size: 0.95rem;
    }

    @media (max-width: 820px) {
      .review-grid {
        grid-template-columns: 1fr;
      }

      .score-card {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="page-container">
    <a href="/movies" class="back-link">← Back to Movies</a>

    <section class="card">
      <div class="movie-header">
        <div style="flex:1; min-width:280px;">
          <h1 class="movie-title"><%= movie.title %></h1>

          <p class="movie-meta">
            <strong>Genre:</strong>
            <%= movie.genre || "Not provided" %>
          </p>

          <p class="movie-meta">
            <strong>Director:</strong>
            <%= movie.director && movie.director.trim() !== "" ? movie.director : "Not provided" %>
          </p>

          <p class="movie-meta">
            <strong>Release Year:</strong>
            <%= movie.releaseYear ? movie.releaseYear : "Not provided" %>
          </p>

          <p class="movie-meta" style="margin-top:14px; line-height:1.7; color:#374151;">
            <strong>Description:</strong><br>
            <%= movie.description && movie.description.trim() !== "" ? movie.description : "No description available." %>
          </p>
        </div>

        <div class="stats-box">
          <p class="stats-number"><%= averageRating.toFixed(1) %> / 5.0</p>
          <p class="stats-sub">
            <%= reviewCount === 0 ? "No reviews yet" : `Average rating from ${reviewCount} review${reviewCount === 1 ? "" : "s"}` %>
          </p>
          <div class="stars-display">
            <% const roundedAvg = Math.round(Number(averageRating)); %>
            <% for (let i = 1; i <= 5; i++) { %>
              <%= i <= roundedAvg ? "★" : "☆" %>
            <% } %>
          </div>
        </div>
      </div>
    </section>

    <%
      let myReviewFromList = null;
      let otherReviews = [];

      reviews.forEach(review => {
        if (!review.userId) {
          otherReviews.push(review);
        } else if (user && review.userId._id.toString() === user.id.toString()) {
          myReviewFromList = review;
        } else {
          otherReviews.push(review);
        }
      });
    %>

    <section class="card">
      <% if (!user) { %>
        <div class="notice">
          Please <a href="/user/login">log in</a> to view your review options.
        </div>
      <% } %>

      <% if (user && myReview) { %>
        <div class="notice">
          You have already reviewed this movie. You can edit or delete your review below.
        </div>
      <% } %>

      <% if (user && !myReview && hasWatched) { %>
        <div class="notice">
          You have watched this movie before. You can write your review now.
        </div>

        <div class="btn-row">
          <a href="/reviews/movie/<%= movie._id %>/new" class="btn btn-primary">Write Review</a>
        </div>
      <% } %>

      <% if (user && !myReview && !hasWatched) { %>
        <div class="notice">
          Not watched yet. Add this movie to your watchlist first in order to review it.
        </div>

        <div class="btn-row">
          <form action="/watchlist/add/<%= movie._id %>" method="POST" style="margin:0;">
            <input type="hidden" name="returnTo" value="/watchlist">
            <button type="submit" class="btn btn-primary">Add to Watchlist</button>
          </form>
        </div>
      <% } %>
    </section>

    <section class="card">
      <% if (user && myReview) { %>
        <h2 class="section-title">Your Review</h2>
        <p style="margin-top: -6px; margin-bottom: 18px; color: #6b7280; font-size: 14px;">
          Full rating and review details are shown on this page.
        </p>

        <div class="review-list" style="margin-bottom: 24px;">
          <article class="review-item own-review-card">
            <div class="review-grid">
              <div>
                <div class="review-top">
                  <div class="reviewer-name">
                    <%= (user && (user.username || user.fullname || user.fullName)) || (myReview.userId && (myReview.userId.username || myReview.userId.fullname || myReview.userId.fullName)) || "You" %>
                    <span class="you-badge">(You)</span>
                  </div>

                  <div class="rating-pill">
                    <span><%= myReview.rating.toFixed(1) %>/5.0</span>
                    <span class="mini-stars">
                      <% for (let i = 1; i <= 5; i++) { %>
                        <%= i <= Math.round(myReview.rating) ? "★" : "☆" %>
                      <% } %>
                    </span>
                  </div>
                </div>

                <h3 class="review-headline"><%= myReview.headline ? myReview.headline : "Untitled Review" %></h3>

                <% if (myReview.reviewText && myReview.reviewText.trim() !== "") { %>
                  <p class="review-text"><%= myReview.reviewText %></p>
                <% } else { %>
                  <p class="review-text" style="color:#6b7280; font-style:italic;">No written review provided.</p>
                <% } %>

                <small class="review-date">
                  Posted on
                  <%= new Date(myReview.createdAt).toLocaleDateString("en-GB") %>
                  at
                  <%= new Date(myReview.createdAt).toLocaleTimeString("en-GB", {
                    hour: "2-digit",
                    minute: "2-digit",
                    second: "2-digit",
                    hour12: false
                  }) %>
                </small>

                <% if (myReview.isEdited) { %>
                  <p class="review-date review-edited">
                    Edited on
                    <%= new Date(myReview.updatedAt).toLocaleDateString("en-GB") %>
                    at
                    <%= new Date(myReview.updatedAt).toLocaleTimeString("en-GB", {
                      hour: "2-digit",
                      minute: "2-digit",
                      second: "2-digit",
                      hour12: false
                    }) %>
                  </p>
                <% } %>

                <div class="review-owner-actions">
                  <a href="/reviews/<%= myReview._id %>/edit" class="btn btn-primary">Edit</a>
                  <form action="/reviews/<%= myReview._id %>/delete" method="POST" style="margin:0;">
                    <button type="submit" class="btn btn-danger">Delete</button>
                  </form>
                </div>
              </div>

              <aside class="score-card">
                <div class="score-card-head">
                  <span>Overall</span>
                  <span class="score-card-score"><%= myReview.rating != null ? myReview.rating.toFixed(1) + " / 5.0" : "-" %></span>
                </div>
                <div class="score-card-body">
                  <div class="score-row">
                    <span class="score-label">Story</span>
                    <span class="score-value"><%= myReview.storyRating != null ? myReview.storyRating.toFixed(1) : "-" %></span>
                  </div>
                  <div class="score-row">
                    <span class="score-label">Acting/Cast</span>
                    <span class="score-value"><%= myReview.actingRating != null ? myReview.actingRating.toFixed(1) : "-" %></span>
                  </div>
                  <div class="score-row">
                    <span class="score-label">Music</span>
                    <span class="score-value"><%= myReview.musicRating != null ? myReview.musicRating.toFixed(1) : "-" %></span>
                  </div>
                  <div class="score-row">
                    <span class="score-label">Rewatch Value</span>
                    <span class="score-value"><%= myReview.rewatchRating != null ? myReview.rewatchRating.toFixed(1) : "-" %></span>
                  </div>
                </div>
              </aside>
            </div>
          </article>
        </div>

        <h2 class="section-title">Other Public Reviews</h2>
        <p style="margin-top: -6px; margin-bottom: 18px; color: #6b7280; font-size: 14px;">
          Other users’ ratings and reviews for this movie are shown here.
        </p>

        <% if (otherReviews.length === 0) { %>
          <p class="empty-state">No other public reviews yet.</p>
        <% } else { %>
          <div class="review-list">
            <% otherReviews.forEach(function(review) { %>
              <article class="review-item">
                <div class="review-grid">
                  <div>
                    <div class="review-top">
                      <div class="reviewer-name">
                        <%= review.userId ? (review.userId.fullname || review.userId.username) : "Deleted User" %>
                      </div>
                      <div class="rating-pill">
                        <span><%= review.rating.toFixed(1) %>/5.0</span>
                        <span class="mini-stars">
                          <% for (let i = 1; i <= 5; i++) { %>
                            <%= i <= Math.round(review.rating) ? "★" : "☆" %>
                          <% } %>
                        </span>
                      </div>
                    </div>

                    <h3 class="review-headline"><%= review.headline ? review.headline : "Untitled Review" %></h3>

                    <% if (review.reviewText && review.reviewText.trim() !== "") { %>
                      <p class="review-text"><%= review.reviewText %></p>
                    <% } else { %>
                      <p class="review-text" style="color:#6b7280; font-style:italic;">No written review provided.</p>
                    <% } %>

                    <small class="review-date">
                      Posted on
                      <%= new Date(review.createdAt).toLocaleDateString("en-GB") %>
                      at
                      <%= new Date(review.createdAt).toLocaleTimeString("en-GB", {
                        hour: "2-digit",
                        minute: "2-digit",
                        second: "2-digit",
                        hour12: false
                      }) %>
                    </small>

                    <% if (review.isEdited) { %>
                      <p class="review-date review-edited">
                        Edited on
                        <%= new Date(review.updatedAt).toLocaleDateString("en-GB") %>
                        at
                        <%= new Date(review.updatedAt).toLocaleTimeString("en-GB", {
                          hour: "2-digit",
                          minute: "2-digit",
                          second: "2-digit",
                          hour12: false
                        }) %>
                      </p>
                    <% } %>
                  </div>

                  <aside class="score-card">
                    <div class="score-card-head">
                      <span>Overall</span>
                      <span class="score-card-score"><%= review.rating != null ? review.rating.toFixed(1) + " / 5.0" : "-" %></span>
                    </div>
                    <div class="score-card-body">
                      <div class="score-row">
                        <span class="score-label">Story</span>
                        <span class="score-value"><%= review.storyRating != null ? review.storyRating.toFixed(1) : "-" %></span>
                      </div>
                      <div class="score-row">
                        <span class="score-label">Acting/Cast</span>
                        <span class="score-value"><%= review.actingRating != null ? review.actingRating.toFixed(1) : "-" %></span>
                      </div>
                      <div class="score-row">
                        <span class="score-label">Music</span>
                        <span class="score-value"><%= review.musicRating != null ? review.musicRating.toFixed(1) : "-" %></span>
                      </div>
                      <div class="score-row">
                        <span class="score-label">Rewatch Value</span>
                        <span class="score-value"><%= review.rewatchRating != null ? review.rewatchRating.toFixed(1) : "-" %></span>
                      </div>
                    </div>
                  </aside>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>

      <% } else { %>
        <h2 class="section-title">Public Reviews</h2>

        <% if (reviews.length === 0) { %>
          <p class="empty-state">No reviews yet. Be the first to rate this movie.</p>
        <% } else { %>
          <div class="review-list">
            <% reviews.forEach(function(review) { %>
              <article class="review-item">
                <div class="review-grid">
                  <div>
                    <div class="review-top">
                      <div class="reviewer-name">
                        <%= review.userId ? (review.userId.fullname || review.userId.username) : "Deleted User" %>
                      </div>
                      <div class="rating-pill">
                        <span><%= review.rating.toFixed(1) %>/5.0</span>
                        <span class="mini-stars">
                          <% for (let i = 1; i <= 5; i++) { %>
                            <%= i <= Math.round(review.rating) ? "★" : "☆" %>
                          <% } %>
                        </span>
                      </div>
                    </div>

                    <h3 class="review-headline"><%= review.headline ? review.headline : "Untitled Review" %></h3>

                    <% if (review.reviewText && review.reviewText.trim() !== "") { %>
                      <p class="review-text"><%= review.reviewText %></p>
                    <% } else { %>
                      <p class="review-text" style="color:#6b7280; font-style:italic;">No written review provided.</p>
                    <% } %>

                    <small class="review-date">
                      Posted on
                      <%= new Date(review.createdAt).toLocaleDateString("en-GB") %>
                      at
                      <%= new Date(review.createdAt).toLocaleTimeString("en-GB", {
                        hour: "2-digit",
                        minute: "2-digit",
                        second: "2-digit",
                        hour12: false
                      }) %>
                    </small>

                    <% if (review.isEdited) { %>
                      <p class="review-date review-edited">
                        Edited on
                        <%= new Date(review.updatedAt).toLocaleDateString("en-GB") %>
                        at
                        <%= new Date(review.updatedAt).toLocaleTimeString("en-GB", {
                          hour: "2-digit",
                          minute: "2-digit",
                          second: "2-digit",
                          hour12: false
                        }) %>
                      </p>
                    <% } %>
                  </div>

                  <aside class="score-card">
                    <div class="score-card-head">
                      <span>Overall</span>
                      <span class="score-card-score"><%= review.rating != null ? review.rating.toFixed(1) + " / 5.0" : "-" %></span>
                    </div>
                    <div class="score-card-body">
                      <div class="score-row">
                        <span class="score-label">Story</span>
                        <span class="score-value"><%= review.storyRating != null ? review.storyRating.toFixed(1) : "-" %></span>
                      </div>
                      <div class="score-row">
                        <span class="score-label">Acting/Cast</span>
                        <span class="score-value"><%= review.actingRating != null ? review.actingRating.toFixed(1) : "-" %></span>
                      </div>
                      <div class="score-row">
                        <span class="score-label">Music</span>
                        <span class="score-value"><%= review.musicRating != null ? review.musicRating.toFixed(1) : "-" %></span>
                      </div>
                      <div class="score-row">
                        <span class="score-label">Rewatch Value</span>
                        <span class="score-value"><%= review.rewatchRating != null ? review.rewatchRating.toFixed(1) : "-" %></span>
                      </div>
                    </div>
                  </aside>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      <% } %>
    </section>
  </div>
</body>
</html>