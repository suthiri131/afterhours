<%# thet %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= movie.title %> - Movie Details</title>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #f7f8fc, #eef1f8);
      color: #1f2937;
    }

    .page-container {
      width: 92%;
      max-width: 1120px;
      margin: 35px auto;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 20px;
      text-decoration: none;
      color: #374151;
      font-weight: bold;
    }

    .card {
      background: #ffffff;
      border-radius: 18px;
      padding: 24px;
      margin-bottom: 22px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.07);
    }

    .movie-header {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .details-movie-title {
      margin: 0 0 10px 0;
      font-size: 2rem;
    }

    .movie-meta {
      margin: 8px 0;
      color: #4b5563;
      font-size: 1rem;
    }

    .stats-box {
      min-width: 250px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 18px;
    }

    .stats-number {
      font-size: 2rem;
      font-weight: 700;
      color: #111827;
      margin: 0;
    }

    .stats-sub {
      margin: 6px 0 0 0;
      color: #6b7280;
    }

    .stars-display {
      color: #f5b301;
      letter-spacing: 2px;
      font-size: 1.2rem;
      margin-top: 8px;
    }

    .btn-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .action-btn {
      display: inline-block;
      padding: 11px 18px;
      text-decoration: none;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: bold;
      font-size: 0.95rem;
      transition: 0.2s ease;
    }

    .action-btn:hover {
      transform: translateY(-1px);
      opacity: 0.95;
    }

    .action-btn-primary {
      background: #111827;
      color: white;
    }

    .action-btn-danger {
      background: #d93025;
      color: white;
    }

    .section-title {
      margin: 0 0 16px 0;
      font-size: 1.35rem;
    }

    .review-list {
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .review-item {
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 18px;
      background: #fcfcfd;
    }

    .own-review-card {
      border: 2px solid #dbeafe;
      background: #f8fbff;
    }

    .review-grid {
      display: grid;
      grid-template-columns: 1fr 210px;
      gap: 18px;
      align-items: start;
    }

    .review-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .reviewer-name {
      font-weight: 700;
      font-size: 1rem;
    }

    .you-badge {
      margin-left: 8px;
      font-size: 0.9rem;
      color: #2563eb;
      font-weight: 600;
    }

    .rating-pill {
      background: #eaf1f8;
      color: #27415d;
      border: 1px solid #d4e1ed;
      border-radius: 999px;
      padding: 7px 12px;
      font-weight: bold;
      font-size: 0.95rem;
    }

    .mini-stars {
      color: #f5b301;
      letter-spacing: 1px;
      margin-left: 6px;
    }

    .review-headline {
      margin: 10px 0 8px 0;
      font-size: 1.5rem;
      font-weight: 700;
      color: #1f2937;
    }

    .review-text {
      margin: 10px 0 0 0;
      line-height: 1.7;
      white-space: pre-wrap;
      color: #1f2937;
    }

    .review-date {
      display: block;
      margin-top: 12px;
      color: #6b7280;
      font-size: 0.9rem;
    }

    .review-edited {
      margin-top: 6px;
      color: #6b7280;
      font-size: 0.9rem;
    }

    .review-owner-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .score-card {
      background: #f8fafc;
      border: 1px solid #dbe3ea;
      border-radius: 14px;
      overflow: hidden;
      min-width: 170px;
    }

    .score-card-head {
      background: #eaf1f8;
      padding: 12px 14px;
      border-bottom: 1px solid #dbe3ea;
      font-weight: 700;
      color: #27415d;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .score-card-score {
      font-weight: 800;
      color: #1d4b7a;
    }

    .score-card-body {
      padding: 12px 14px;
    }

    .score-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      padding: 7px 0;
      border-bottom: 1px solid #edf2f7;
      font-size: 0.95rem;
    }

    .score-row:last-child {
      border-bottom: none;
    }

    .score-label {
      color: #374151;
      font-weight: 600;
    }

    .score-value {
      color: #111827;
      font-weight: 700;
    }

    .empty-state {
      color: #6b7280;
      margin: 0;
    }

    .notice {
      padding: 16px 18px;
      border-radius: 12px;
      background: #fff7ed;
      color: #9a3412;
      border: 1px solid #fdba74;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .notice-info {
      background: #eff6ff;
      color: #1d4ed8;
      border: 1px solid #93c5fd;
    }

    .notice-success {
      background: #ecfdf3;
      color: #166534;
      border: 1px solid #86efac;
    }

    .notice-error {
      background: #fee2e2;
      color: #991b1b;
      border: 1px solid #fca5a5;
    }

    .suggested-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-top: 18px;
    }

    /* Reused movie-page card styles for suggested movies */
    .movie-card {
      background-color: white;
      border-radius: 14px;
      border: 1px solid #e5e7eb;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      width: 100%;
      max-width: 300px;
      margin: 0;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .movie-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.1);
    }

    .movie-banner {
      height: 410px;
      min-height: 410px;
      max-width: 300px;
      width: 100%;
      background-color: #14213d;
      overflow: hidden;
      display: block;
    }

    .movie-banner img {
      height: 100%;
      width: 100%;
      object-fit: cover;
    }

    .movie-content {
      padding: 14px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .card-movie-title {
      font-size: 16px;
      line-height: 1.4;
      margin: 0 0 8px;
      color: #14213d;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .movie-info {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .badge {
      padding: 4px 8px;
      border-radius: 999px;
      background-color: #eef2ff;
      font-size: 11px;
      color: #14213d;
    }

    .description {
      font-size: 13px;
      color: #4b5563;
      margin: 0 0 6px;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .director {
      font-size: 12px;
      color: #374151;
      margin: 0 0 10px;
    }

    .watchlist-form {
      margin-top: auto;
    }

    .movie-card-btn {
      width: 100%;
      border: none;
      border-radius: 8px;
      padding: 10px;
      background-color: #14213d;
      color: white;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
    }

    .movie-card-btn:hover {
      background-color: #1f325c;
    }

    @media (max-width: 1100px) {
      .suggested-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 820px) {
      .review-grid {
        grid-template-columns: 1fr;
      }

      .score-card {
        width: 100%;
      }

      .suggested-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <script>
    if ("scrollRestoration" in history) {
      history.scrollRestoration = "manual";
    }
  </script>
  <link rel="stylesheet" href="/css/review-movie-poster.css" />
</head>
<body>
  <%- include("navbar") %>
  <div class="page-container">
    <section class="card">
      <%- include("review-movie-poster", {
        movie: movie,
        showAverageBox: true,
        averageRating: averageRating,
        reviewCount: reviewCount
      }) %>
    </section>

    <%
      const otherReviews = reviews.filter(review =>
        !user || !review.userId || review.userId._id.toString() !== user.id.toString()
      );
    %>

    <section class="card">
      <% if (!user) { %>
        <div class="notice">
          Please <a href="/user/login">log in</a> to view your review options.
        </div>

      <% } else if (myReview) { %>
        <div class="notice notice-info">
          You have already reviewed this movie. You can edit or delete your review below.
        </div>

      <% } else if (hasWatched) { %>
        <div class="notice notice-info">
          You have watched this movie before. You can write your review now.
        </div>

        <div class="btn-row">
          <a href="/reviews/movie/<%= movie._id %>/new" class="action-btn action-btn-primary">Write Review</a>
        </div>

      <% } else if (isInWatchlist) { %>
        <div class="notice notice-success">
          Added to watchlist. Go to Watchlist to mark as watched and review.
        </div>

      <% } else { %>
        <div class="notice">
          Not watched yet. Add this movie to your watchlist first in order to review it.
        </div>

        <div class="btn-row">
          <form action="/watchlist/add/<%= movie._id %>" method="POST" style="margin:0;">
            <input type="hidden" name="returnTo" value="/movies/<%= movie._id %>">
            <button type="submit" class="action-btn action-btn-primary">Add to Watchlist</button>
          </form>
        </div>
      <% } %>
    </section>

    <section class="card">
      <% if (user && myReview) { %>
        <h2 class="section-title">Your Review</h2>
        <p style="margin-top: -6px; margin-bottom: 18px; color: #6b7280; font-size: 14px;">
          Full rating and review details are shown on this page.
        </p>

        <div class="review-list" style="margin-bottom: 24px;">
          <%- include("review-card", { review: myReview, isOwner: true, user: user }) %>
        </div>

        <h2 class="section-title">Other Public Reviews</h2>
        <p style="margin-top: -6px; margin-bottom: 18px; color: #6b7280; font-size: 14px;">
          Other users’ ratings and reviews for this movie are shown here.
        </p>

        <% if (otherReviews.length === 0) { %>
          <p class="empty-state">No other public reviews yet.</p>
        <% } else { %>
          <div class="review-list">
            <% otherReviews.forEach(function(review) { %>
              <%- include("review-card", { review: review, isOwner: false, user: user }) %>
            <% }) %>
          </div>
        <% } %>

      <% } else { %>
        <h2 class="section-title">Public Reviews</h2>

        <% if (reviews.length === 0) { %>
          <p class="empty-state">No reviews yet. Be the first to rate this movie.</p>
        <% } else { %>
          <div class="review-list">
            <% reviews.forEach(function(review) { %>
              <%- include("review-card", { review: review, isOwner: false, user: user }) %>
            <% }) %>
          </div>
        <% } %>
      <% } %>
    </section>
    <section class="card" id="suggested-movies">
      <h2 class="section-title">Suggested Movies</h2>
      <p style="margin-top: -6px; margin-bottom: 18px; color: #6b7280; font-size: 14px;">
        More <%= movie.genre && movie.genre.name ? movie.genre.name : "similar" %> movies you may like.
      </p>

      <% if (typeof suggestedMsg !== "undefined" && suggestedMsg) { %>
      <div
        class="notice <%= suggestedMsg.includes('Successfully') ? 'notice-success' : 'notice-error' %>"
        style="margin-bottom: 18px;">
        <%= suggestedMsg %>
      </div>
    <% } %>

      <% if (!suggestedMovies || suggestedMovies.length === 0) { %>
        <p class="empty-state">No similar movies available yet.</p>
      <% } else { %>
        <div class="suggested-grid">
          <% suggestedMovies.forEach(suggestedMovie => { %>
            <div class="movie-card">
              <div class="movie-banner">
                <a href="/movies/<%= suggestedMovie._id %>" style="display:block; width:100%; height:100%;">
                  <% if (suggestedMovie.movieImage) { %>
                    <img src="<%= suggestedMovie.movieImage %>" alt="<%= suggestedMovie.title %>" style="width: 100%; height: 100%; object-fit: cover;">
                  <% } else { %>
                    <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:white; font-size:48px; font-weight:bold;">
                      <%= suggestedMovie.title ? suggestedMovie.title.charAt(0).toUpperCase() : "M" %>
                    </div>
                  <% } %>
                </a>
              </div>

              <div class="movie-content">
                <h2 class="card-movie-title">
                  <a href="/movies/<%= suggestedMovie._id %>" style="text-decoration:none; color:inherit;">
                    <%= suggestedMovie.title %>
                  </a>
                </h2>

                <div class="movie-info">
                  <span class="badge"><%= suggestedMovie.genre ? suggestedMovie.genre.name : "Unknown Genre" %></span>
                  <% if (suggestedMovie.releaseYear) { %>
                    <span class="badge"><%= suggestedMovie.releaseYear %></span>
                  <% } %>
                </div>

                <p class="description">
                  <%= suggestedMovie.description && suggestedMovie.description.trim() !== ""
                    ? suggestedMovie.description
                    : "No description available" %>
                </p>

                <p class="director">
                  <strong>Director:</strong>
                  <%= suggestedMovie.director && suggestedMovie.director.trim() !== "" ? suggestedMovie.director : "Unknown" %>
                </p>

                <div style="
                  margin: 0 0 10px;
                  padding: 8px 10px;
                  border-radius: 10px;
                  background: #eff6ff;
                  border: 1px solid #bfdbfe;
                  color: #1d4ed8;
                  font-size: 12px;
                  font-weight: 700;
                  text-align: center;
                  line-height: 1.4;
                ">
                  ⭐ Wanna watch it?<br>Click the poster or title to check the reviews first.
                </div>

                <% const isSuggestedInWatchlist = user && activeWatchlistMovieIds.includes(suggestedMovie._id.toString()); %>
                <% if (isSuggestedInWatchlist) { %>
                  <div class="notice notice-success" style="margin-top:auto; padding:10px; text-align:center; font-size:13px;">
                    Added to watchlist
                  </div>
                <% } else { %>
                  <form class="watchlist-form suggested-watchlist-form" action="/watchlist/add/<%= suggestedMovie._id %>" method="POST">
                    <input type="hidden" name="returnTo" value="/movies/<%= movie._id %>">
                    <button type="submit" class="movie-card-btn">Add to Watchlist</button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const savedScrollY = sessionStorage.getItem("movieDetailsScrollY");
      if (savedScrollY !== null) {
        window.scrollTo(0, parseInt(savedScrollY, 10));
        sessionStorage.removeItem("movieDetailsScrollY");
      }

      const suggestedForms = document.querySelectorAll(".suggested-watchlist-form");
      suggestedForms.forEach(form => {
        form.addEventListener("submit", function () {
          sessionStorage.setItem("movieDetailsScrollY", window.scrollY);
        });
      });
    });
  </script>
</body>
</html>